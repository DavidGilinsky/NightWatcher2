# NightWatcher2 daemon configuration (INI-style).
# Copy to /etc/nightwatcher/nightwatcher.conf and edit for your site.

[daemon]
# Sensors are registered in the database with `nwdb add-sensor`, and each sensor's
# poll cadence is its own poll_interval_s column (nwdb set-sensor --poll-interval).
# This file only configures the daemon itself: the database connection and API port.

[database]
host = 127.0.0.1
port = 3306
name = nightwatcher
user = nightwatcher
# The database password is read from the environment variable NW_DB_PASSWORD.
# Never store secrets in this file or commit them to git.

[api]
# Built-in HTTP server (REST API + web UI).
port = 8080
bind = 127.0.0.1
# Path to schema.sql, used by POST /api/v1/db/init to create any missing tables.
schema_file = /usr/share/nightwatcher/schema.sql
# Static web UI directory, served at / (set once the UI is installed).
# web_root = /usr/share/nightwatcher/web
# Writes require an admin login session (an 'admin'/'admin' account is seeded on first
# start; change the password). An optional static token for scripts may be set via
# NW_API_TOKEN (never stored here).
