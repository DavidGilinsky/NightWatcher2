# ---------------------------------------------------------------------------
# Author:        David Gilinsky
# File:          config/systemd/nightwatcherd.service.in
# Purpose:       systemd service unit for nightwatcherd. `@CMAKE_INSTALL_PREFIX@`
#                is substituted at build time; `make install` symlinks the
#                generated unit into /etc/systemd/system.
# Created:       2026-07-18
# Last Modified: 2026-07-20
# Version:       0.1.0
# ---------------------------------------------------------------------------
[Unit]
Description=NightWatcher2 SQM daemon
Documentation=https://github.com/DavidGilinsky/NightWatcher2
After=network-online.target mariadb.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=@CMAKE_INSTALL_PREFIX@/bin/nightwatcherd --config /etc/nightwatcher/nightwatcher.conf
Restart=on-failure
RestartSec=5

# Database password (and any other secrets) live here, mode 0600, not in git:
#   /etc/nightwatcher/nightwatcher.env  ->  NW_DB_PASSWORD=...
EnvironmentFile=-/etc/nightwatcher/nightwatcher.env

# Runtime hardening (skeleton defaults — revisit as features land).
DynamicUser=yes
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
# SQM-LU (USB serial) access: the DynamicUser is put in the dialout group so it
# can open /dev/ttyUSB* (root:dialout 0660). Comment out if you use TCP only.
SupplementaryGroups=dialout

[Install]
WantedBy=multi-user.target
