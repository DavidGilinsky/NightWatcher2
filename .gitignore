# ---------------------------------------------------------------------------
# Author:        David Gilinsky
# File:          .gitignore
# Purpose:       Git ignore rules (build output, CMake artifacts, local secrets).
# Created:       2026-07-18
# Last Modified: 2026-07-18
# Version:       0.1.0
# ---------------------------------------------------------------------------

# Build directories
/build/
/build-*/
/pkg/
/out/

# Package artifacts
*.deb

# CMake artifacts
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Testing/
compile_commands.json

# Object / library / binary files
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.exe

# Test scratch files
test_nightwatcher.conf

# Local secrets / env
*.env
nightwatcher.env
*.local.conf

# Local scratch + credentials (OAuth client JSON, service-account keys, sample data)
/sample/

# Database dumps / backups are ignored anywhere in the tree: a `nwdb backup`
# contains secrets in the clear (Drive refresh token, weather API keys, user
# password hashes). Only the schema/setup/migration SQL is tracked.
*.sql
!sql/schema.sql
!sql/setup.sql
!sql/migrations/*.sql

# SQM/observation data exports
*.dat

# TLS material — auto-generated self-signed certs and (secret) private keys must
# never be committed. The daemon writes these to a tls/ dir beside the config.
*.pem
*.key
*-cert.pem
*-key.pem
tls/

# Editor / IDE
*.swp
*~
.vscode/
.idea/
.cache/

# Local tooling (not shared)
.claude/settings.local.json
.qodo/
