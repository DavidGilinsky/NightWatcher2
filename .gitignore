# ---------------------------------------------------------------------------
# Author:        David Gilinsky
# File:          .gitignore
# Purpose:       Git ignore rules (build output, CMake artifacts, local secrets).
# Created:       2026-07-18
# Last Modified: 2026-07-18
# Version:       0.1.0
# ---------------------------------------------------------------------------

# Build directories
/build/
/build-*/
/out/

# CMake artifacts
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Testing/
compile_commands.json

# Object / library / binary files
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.exe

# Test scratch files
test_nightwatcher.conf

# Local secrets / env
*.env
nightwatcher.env

# Editor / IDE
*.swp
*~
.vscode/
.idea/
.cache/

# Local tooling (not shared)
.claude/settings.local.json
.qodo/
